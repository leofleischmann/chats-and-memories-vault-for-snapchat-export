# SnapChat Search App
MEILI_MASTER_KEY=masterKey

# Immich version (pinned for stability)
IMMICH_VERSION=v2.5.6

# Immich database credentials
IMMICH_DB_PASSWORD=postgres
IMMICH_DB_USERNAME=postgres
IMMICH_DB_NAME=immich

# Immich storage locations (relative to project root)
UPLOAD_LOCATION=./immich-data/library
DB_DATA_LOCATION=./immich-data/postgres

# Enable detailed file logging inside the backend container
LOG_TO_FILES=0
LOG_LEVEL=DEBUG
LOG_CONSOLE_LEVEL=INFO
